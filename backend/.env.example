# ── Ollama (Gemma + embeddings) — defaults in llm_providers.py
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=gemma4:e4b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Skip local HuggingFace cross-encoder rerank (saves ~2GB download) — recommended on small VMs
# LOCAL_RERANK_ENABLED=false

NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_DATABASE=neo4j
# Optional: recycle driver connections before server idle timeout (seconds). Default 3300 (~55m).
# NEO4J_MAX_CONNECTION_LIFETIME=3300

# Optional LangSmith tracing for local debugging. Leave disabled for the judged demo.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=GroundedMD-Hackathon
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Retrieval post-processing tuning (optional):
# MMR_LAMBDA=0.5          # 0=max diversity, 1=max relevance (default: 0.5)
# MMR_FETCH_MULTIPLIER=3  # fetch top_k × N candidates before MMR (default: 3)
# MMR_KEEP_MULTIPLIER=2   # keep top_k × N after MMR (default: 2)

