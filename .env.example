# ── Neo4j ──────────────────────────────────────────────────────────────────
# Neo4j Aura (cloud) — get your connection string from console.neo4j.io
NEO4J_URI=neo4j+s://<your-aura-instance-id>.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=<your-aura-password>

# Local Neo4j alternative (docker-compose spins one up automatically)
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=groundedmd

# ── Ollama ─────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=gemma4:e4b          # or gemma4:27b for higher quality
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Reranker (downloaded from Hugging Face on first use) ──────────────────
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
LOCAL_RERANK_ENABLED=false

# ── Optional: LangSmith tracing ───────────────────────────────────────────
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=GroundedMD-Hackathon
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
